{
   "name": "suraj-portfolio",
   "version": "1.0.0",
   "description": "",
   "main": "index.js",
   "scripts": {
      "postinstall": "npm install --prefix client && npm install --prefix server",
      "prepare": "husky",
      "migrate": "npm run migrate --prefix server",
      "format": "prettier . --write -c",
      "format:check": "prettier . -c",
      "client:dev": "npm run dev --prefix client",
      "client:build": "npm run build --prefix client",
      "server:dev": "npm run dev --prefix server",
      "server:start": "npm run start --prefix server"
   },
   "keywords": [],
   "author": "",
   "license": "ISC",
   "type": "commonjs",
   "devDependencies": {
      "autoprefixer": "^10.4.23",
      "lint-staged": "^16.2.7",
      "postcss": "^8.5.6",
      "prettier": "3.7.4",
      "tailwindcss": "^4.1.18"
   },
   "lint-staged": {
      "client/src/**/*.{js,jsx,ts,tsx}": [
         "prettier --write",
         "eslint --fix"
      ],
      "server/src/**/*.{js,jsx}": [
         "prettier --write"
      ],
      "**/*.{json,md,html,css}": [
         "prettier --write"
      ]
   },
   "dependencies": {
      "axios": "^1.13.2",
      "clsx": "^2.1.1",
      "framer-motion": "^12.29.0",
      "lucide-react": "^0.563.0",
      "tailwind-merge": "^3.4.0"
   }
}